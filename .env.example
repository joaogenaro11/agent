# ============================================================
# Assessor Pessoal de IA — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# ============================================================

# --- Banco de dados (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/assessor_ia"

# --- OpenAI ---
# Opcional no MVP: sem a chave, o assistente roda em "modo degradado"
# (interpretação por regex + mensagens via templates).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Aplicação ---
APP_URL=http://localhost:3000
DEFAULT_TIMEZONE=America/Sao_Paulo

# --- WhatsApp ---
# Provedor ativo: twilio | mock | meta (futuro) | twilio_business (futuro)
WHATSAPP_PROVIDER=mock

# Twilio WhatsApp Sandbox (MVP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
MY_WHATSAPP_NUMBER=whatsapp:+55SEUNUMERO

# Validação de assinatura do webhook Twilio (recomendado em produção)
TWILIO_VALIDATE_SIGNATURE=false

# Meta WhatsApp Cloud API (futuro — não usado no MVP)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_VERIFY_TOKEN=

# --- Scheduler / worker ---
# Liga o registro do job recorrente no processo worker (npm run worker).
JOB_RUNNER_ENABLED=true

    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "luxon": "^3.7.2",
    "next": "^15.5.4",
    "openai": "^6.39.0",

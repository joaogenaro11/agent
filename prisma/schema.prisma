// Assessor Pessoal de IA — schema do banco de dados
// Single-user no MVP, porém toda entidade carrega `userId` para multiusuário futuro.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------- Enums -----------------------------

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ReminderStatus {
  PENDING
  COMPLETED
  POSTPONED
  CANCELLED
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum Channel {
  WHATSAPP
  WEB
  BOTH
}

enum ReminderSource {
  WEB
  WHATSAPP
  APPLE_REMINDERS_FUTURE
}

enum Tone {
  LEVE
  DIRETO
  INTENSO
  ESPIRITUAL
  EXECUTIVO
  AMIGAVEL
}

enum AccountabilityLevel {
  BAIXO
  MEDIO
  ALTO
}

enum MessageLength {
  CURTA
  MEDIA
  DETALHADA
}

enum AssistantMode {
  NORMAL
  COBRANCA_ALTA
  LEVE
  FOCO
  DESCANSO
}

enum RoutineType {
  MOTIVACIONAL
  DEVOCIONAL
  HABITO
  LEMBRETE
  CHECKLIST
}

enum ScheduledMessageType {
  MOTIVACIONAL
  DEVOCIONAL
  COBRANCA
  REVISAO_DIARIA
  PLANEJAMENTO_DIARIO
  LIVRE
}

enum HabitType {
  BOOLEAN
  NUMERIC
  CHECKLIST
}

enum WhatsAppDirection {
  INBOUND
  OUTBOUND
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum PromptType {
  COMMAND_INTERPRETER
  MOTIVATIONAL
  DEVOTIONAL
  ACCOUNTABILITY
  DAILY_REVIEW
  DAILY_PLANNING
  HABIT_MESSAGE
  CHALLENGE_MESSAGE
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

// ----------------------------- Models -----------------------------

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String   @unique
  timezone  String   @default("America/Sao_Paulo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings          AssistantSettings?
  reminders         Reminder[]
  routines          Routine[]
  scheduledMessages ScheduledMessage[]
  habits            Habit[]
  habitLogs         HabitLog[]
  hard75Challenges  Hard75Challenge[]
  hard75DailyLogs   Hard75DailyLog[]
  whatsAppMessages  WhatsAppMessage[]
  deliveryLogs      MessageDeliveryLog[]
  aiLogs            AIInteractionLog[]
  devotionals       DevotionalTemplate[]
  motivationals     MotivationalTemplate[]
  prompts           PromptTemplate[]
  integrations      IntegrationConnection[]
}

model AssistantSettings {
  id                   String              @id @default(cuid())
  userId               String              @unique
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assistantName        String              @default("Nexus")
  userDisplayName      String
  tone                 Tone                @default(DIRETO)
  accountabilityLevel  AccountabilityLevel @default(MEDIO)
  messageLength        MessageLength       @default(MEDIA)
  allowSpiritualContent Boolean            @default(true)
  motivationalStyle    String              @default("")
  devotionalStyle      String              @default("")
  forbiddenTopics      String[]            @default([])
  quietHoursStart      String              @default("22:00")
  quietHoursEnd        String              @default("07:00")
  timezone             String              @default("America/Sao_Paulo")
  allowEmojis          Boolean             @default(true)
  currentMode          AssistantMode       @default(NORMAL)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model Reminder {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  category        String?
  priority        Priority       @default(MEDIUM)
  status          ReminderStatus @default(PENDING)
  dueAt           DateTime
  hasSpecificTime Boolean        @default(true)
  recurrenceType  RecurrenceType @default(NONE)
  recurrenceRule  String?
  reminderOffsets Int[]          @default([])
  channel         Channel        @default(WHATSAPP)
  source          ReminderSource @default(WEB)
  externalId      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  completedAt     DateTime?

  @@index([userId, status])
  @@index([userId, dueAt])
}

model Routine {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  weekdays    Int[]        @default([])
  time        String
  type        RoutineType @default(LEMBRETE)
  baseContent String      @default("")
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId, active])
}

model ScheduledMessage {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         ScheduledMessageType @default(LIVRE)
  title        String
  basePrompt   String               @default("")
  time         String
  weekdays     Int[]                @default([])
  active       Boolean              @default(true)
  useAI        Boolean              @default(true)
  optionalLink String?
  category     String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([userId, active])
}

model Habit {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  type         HabitType @default(BOOLEAN)
  targetValue  Float?
  unit         String?
  activeDays   Int[]     @default([0, 1, 2, 3, 4, 5, 6])
  reminderTime String?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  logs HabitLog[]

  @@index([userId, active])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  value     Float    @default(0)
  completed Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([habitId, date])
  @@index([userId, date])
}

model Hard75Challenge {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate     DateTime        @db.Date
  durationDays  Int             @default(75)
  currentDay    Int             @default(1)
  targetWaterMl Int             @default(3000)
  targetPages   Int             @default(10)
  rules         String          @default("")
  checkInTimes  String[]        @default([])
  active        Boolean         @default(true)
  failedAt      DateTime?
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  dailyLogs Hard75DailyLog[]

  @@index([userId, active])
}

model Hard75DailyLog {
  id            String          @id @default(cuid())
  challengeId   String
  challenge     Hard75Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime        @db.Date
  waterMl       Int             @default(0)
  workout1      Boolean         @default(false)
  workout2      Boolean         @default(false)
  readingDone   Boolean         @default(false)
  pagesRead     Int             @default(0)
  dietDone      Boolean         @default(false)
  progressPhoto Boolean         @default(false)
  devotionalDone Boolean        @default(false)
  notes         String?
  completed     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([challengeId, date])
  @@index([userId, date])
}

model WhatsAppMessage {
  id                String            @id @default(cuid())
  userId            String?
  user              User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  direction         WhatsAppDirection
  from              String
  to                String
  body              String
  providerMessageId String?
  rawPayload        Json?
  createdAt         DateTime          @default(now())

  @@index([userId, createdAt])
}

model MessageDeliveryLog {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  relatedEntityType String
  relatedEntityId   String
  scheduledFor      DateTime
  sentAt            DateTime?
  status            DeliveryStatus @default(PENDING)
  errorMessage      String?
  messageBody       String?
  createdAt         DateTime       @default(now())

  // Deduplicação: um único disparo por (entidade, ocorrência agendada).
  @@unique([relatedEntityType, relatedEntityId, scheduledFor])
  @@index([userId, createdAt])
}

model AIInteractionLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  input     String
  output    String
  intent    String?
  model     String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model DevotionalTemplate {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  theme        String
  verse        String   @default("")
  style        String   @default("")
  size         String   @default("media")
  basePrompt   String   @default("")
  optionalLink String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MotivationalTemplate {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  objective       String   @default("")
  intensity       String   @default("media")
  style           String   @default("")
  allowedThemes   String[] @default([])
  forbiddenThemes String[] @default([])
  basePrompt      String   @default("")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PromptTemplate {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      PromptType
  content   String
  version   Int        @default(1)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId, type])
}

model IntegrationConnection {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  status       IntegrationStatus @default(DISCONNECTED)
  metadata     Json?
  lastSyncedAt DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([userId, provider])
}
